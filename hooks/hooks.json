{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/inject-context.mjs",
            "commandWindows": "node %PLUGIN_ROOT%/hooks/inject-context.mjs",
            "statusMessage": "Axon: loading methodology"
          },
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/auto-attach-hud.mjs",
            "commandWindows": "node %PLUGIN_ROOT%/hooks/auto-attach-hud.mjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/update-state.mjs",
            "commandWindows": "node %PLUGIN_ROOT%/hooks/update-state.mjs",
            "statusMessage": "Axon: tracking state"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/check-finish.mjs",
            "commandWindows": "node %PLUGIN_ROOT%/hooks/check-finish.mjs",
            "statusMessage": "Axon: checking completion"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${PLUGIN_ROOT}/hooks/sync-tasks.mjs",
            "commandWindows": "node %PLUGIN_ROOT%/hooks/sync-tasks.mjs",
            "statusMessage": "Axon: checking task progress"
          }
        ]
      }
    ]
  }
}
