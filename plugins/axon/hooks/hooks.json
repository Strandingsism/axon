{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/inject-context.mjs\"",
            "commandWindows": "node \"${PLUGIN_ROOT}/hooks/inject-context.mjs\"",
            "statusMessage": "Axon: loading methodology"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/record-prompt-skill-event.mjs\"",
            "commandWindows": "node \"${PLUGIN_ROOT}/hooks/record-prompt-skill-event.mjs\"",
            "statusMessage": "Axon: recording explicit skill event"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/record-skill-event.mjs\"",
            "commandWindows": "node \"${PLUGIN_ROOT}/hooks/record-skill-event.mjs\"",
            "statusMessage": "Axon: recording skill event"
          },
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/skill-gate.mjs\"",
            "commandWindows": "node \"${PLUGIN_ROOT}/hooks/skill-gate.mjs\"",
            "statusMessage": "Axon: preparing skill context"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/request-history-summary.mjs\"",
            "commandWindows": "node \"${PLUGIN_ROOT}/hooks/request-history-summary.mjs\"",
            "statusMessage": "Axon: checking history summary"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/sync-tasks.mjs\"",
            "commandWindows": "node \"${PLUGIN_ROOT}/hooks/sync-tasks.mjs\"",
            "statusMessage": "Axon: checking task progress"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/close-prompt-finish-run.mjs\"",
            "commandWindows": "node \"${PLUGIN_ROOT}/hooks/close-prompt-finish-run.mjs\"",
            "statusMessage": "Axon: closing explicit finish run"
          }
        ]
      }
    ]
  }
}
